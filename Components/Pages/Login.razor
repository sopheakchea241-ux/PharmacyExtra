@page "/login"
@inject HttpClient Http
@inject NavigationManager Navigation

<PageTitle>Login</PageTitle>

<div class="row justify-content-center mt-4">
    <div class="col-md-7 col-lg-5 col-xl-4">
        <div class="card shadow-sm border-0">
            <div class="card-body p-4">
                <div class="text-center mb-3">
                    <h1 class="h3 mb-1">Sign in</h1>
                    <p class="text-muted mb-0">Pharmacy Extra Management Portal</p>
                </div>

                <div class="alert alert-info py-2 small" role="alert">
                    Demo account: <code>admin / admin123</code>
                </div>

                <EditForm Model="_model" OnValidSubmit="HandleLogin">
                    <DataAnnotationsValidator />

                    <div class="mb-3">
                        <label class="form-label">Username</label>
                        <InputText class="form-control" @bind-Value="_model.Username" autocomplete="username" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Password</label>
                        <InputText class="form-control" @bind-Value="_model.Password" type="password" autocomplete="current-password" />
                    </div>

                    <button class="btn btn-primary w-100" type="submit">Sign in</button>
                </EditForm>

                @if (!string.IsNullOrWhiteSpace(_error))
                {
                    <div class="alert alert-danger mt-3 mb-0" role="alert">@_error</div>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private LoginModel _model = new();
    private string? _error;

    private async Task HandleLogin()
    {
        _error = null;

        try
        {
            var response = await Http.PostAsJsonAsync("/auth/login", new LoginRequest(
                _model.Username ?? string.Empty,
                _model.Password ?? string.Empty));

            if (!response.IsSuccessStatusCode)
            {
                _error = "Invalid username or password.";
                return;
            }

            Navigation.NavigateTo("/dashboard", forceLoad: true);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private sealed class LoginModel
    {
        public string? Username { get; set; }
        public string? Password { get; set; }
    }

    private sealed record LoginRequest(string Username, string Password);
}
