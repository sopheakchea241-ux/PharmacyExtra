@page "/dashboard"
@attribute [Authorize]
@inject HttpClient Http

<PageTitle>Dashboard</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="mb-0">Operations Dashboard</h1>
        <small class="text-muted">Central monitoring for pharmacy operations and master data.</small>
    </div>
    <button class="btn btn-outline-primary" @onclick="LoadAsync">Refresh</button>
</div>

@if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="alert alert-danger" role="alert">@_error</div>
}

@if (_summary is null || _systemInfo is null)
{
    <div class="card">
        <div class="card-body">Loading dashboard...</div>
    </div>
}
else
{
    <div class="row g-3 mb-3">
        <div class="col-md-6 col-xl-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <small class="text-uppercase text-muted">Commodities</small>
                    <h3 class="mb-0">@_summary.Commodities</h3>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-xl-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <small class="text-uppercase text-muted">Budget Sources</small>
                    <h3 class="mb-0">@_summary.BudgetSources</h3>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-xl-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <small class="text-uppercase text-muted">Facilities</small>
                    <h3 class="mb-0">@_summary.Facilities</h3>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-xl-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <small class="text-uppercase text-muted">Main Transactions</small>
                    <h3 class="mb-0">@_summary.MainTransactions</h3>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white">Quick Actions</div>
                <div class="card-body d-flex flex-wrap gap-2">
                    <a class="btn btn-primary" href="budget-sources">Manage Budget Sources</a>
                    <AuthorizeView Policy="AdminOnly">
                        <a class="btn btn-outline-primary" href="admin/users">Manage Users</a>
                        <a class="btn btn-outline-primary" href="admin/roles">Manage Roles</a>
                    </AuthorizeView>
                    <a class="btn btn-outline-secondary" href="status">System Status</a>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white">System Summary</div>
                <div class="card-body">
                    <dl class="row mb-0 small">
                        <dt class="col-5">Environment</dt>
                        <dd class="col-7">@_systemInfo.Environment</dd>

                        <dt class="col-5">Machine</dt>
                        <dd class="col-7">@_systemInfo.MachineName</dd>

                        <dt class="col-5">Runtime</dt>
                        <dd class="col-7">@_systemInfo.Runtime</dd>

                        <dt class="col-5">Updated</dt>
                        <dd class="col-7">@_summary.GeneratedAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</dd>
                    </dl>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private DashboardSummaryDto? _summary;
    private SystemInfoDto? _systemInfo;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _error = null;
        try
        {
            _summary = await Http.GetFromJsonAsync<DashboardSummaryDto>("/api/dashboard/summary");
            _systemInfo = await Http.GetFromJsonAsync<SystemInfoDto>("/api/system/info");
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private sealed record DashboardSummaryDto(int Commodities, int BudgetSources, int Facilities, int MainTransactions, DateTimeOffset GeneratedAtUtc);
    private sealed record SystemInfoDto(string MachineName, string Environment, DateTimeOffset GeneratedAtUtc, string Runtime, string Application);
}
