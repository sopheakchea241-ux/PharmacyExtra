@page "/admin/roles"
@attribute [Authorize(Policy = "AdminOnly")]
@inject HttpClient Http

<PageTitle>Role Management</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="mb-0">Role Management</h1>
        <small class="text-muted">Manage permission profiles used by system users.</small>
    </div>
    <button class="btn btn-primary" @onclick="NewRole">New Role</button>
</div>

<div class="card mb-3">
    <div class="card-body">
        <div class="row g-2">
            <div class="col-md-6">
                <input class="form-control" placeholder="Search code / name" @bind="_search" />
            </div>
            <div class="col-md-6 d-flex gap-2">
                <button class="btn btn-outline-primary" @onclick="ApplyFilterAsync">Apply</button>
                <button class="btn btn-outline-secondary" @onclick="ResetFilterAsync">Reset</button>
            </div>
        </div>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="alert alert-danger">@_error</div>
}

<div class="row g-3">
    <div class="col-lg-8">
        @if (_result is null)
        {
            <div class="card"><div class="card-body">Loading roles...</div></div>
        }
        else
        {
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span>Total roles: @_result.TotalCount</span>
                    <small class="text-muted">Page @_page of @TotalPages</small>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Code</th>
                                <th>English</th>
                                <th>Khmer</th>
                                <th>Status</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var role in _result.Items)
                            {
                                <tr class="@(role.UserPermissionCode == _form.UserPermissionCode ? "table-active" : null)">
                                    <td>@role.UserPermissionCode</td>
                                    <td>@role.UserPermissionEnglish</td>
                                    <td>@role.UserPermissionKhmer</td>
                                    <td>
                                        <span class="badge @(role.UserPermissionIsActived ? "text-bg-success" : "text-bg-secondary")">
                                            @(role.UserPermissionIsActived ? "Active" : "Inactive")
                                        </span>
                                    </td>
                                    <td class="text-end">
                                        <button class="btn btn-sm btn-outline-primary" @onclick="() => Edit(role)">Edit</button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div class="card-footer d-flex gap-2">
                    <button class="btn btn-outline-secondary btn-sm" disabled="@(_page <= 1)" @onclick="PrevPageAsync">Prev</button>
                    <button class="btn btn-outline-secondary btn-sm" disabled="@(_page >= TotalPages)" @onclick="NextPageAsync">Next</button>
                </div>
            </div>
        }
    </div>

    <div class="col-lg-4">
        <div class="card">
            <div class="card-header">@(_isEdit ? "Edit Role" : "Create Role")</div>
            <div class="card-body">
                <div class="mb-2">
                    <label class="form-label">Role Code</label>
                    <input class="form-control" @bind="_form.UserPermissionCode" disabled="@_isEdit" />
                </div>
                <div class="mb-2">
                    <label class="form-label">English Name</label>
                    <input class="form-control" @bind="_form.UserPermissionEnglish" />
                </div>
                <div class="mb-2">
                    <label class="form-label">Khmer Name</label>
                    <input class="form-control" @bind="_form.UserPermissionKhmer" />
                </div>
                <div class="mb-2">
                    <label class="form-label">Description</label>
                    <textarea class="form-control" rows="2" @bind="_form.UserPermissionDescription"></textarea>
                </div>
                <div class="form-check form-switch mb-3">
                    <input class="form-check-input" type="checkbox" @bind="_form.UserPermissionIsActived" />
                    <label class="form-check-label">Active</label>
                </div>

                <div class="d-flex gap-2">
                    <button class="btn btn-success" @onclick="SaveAsync">@(_isEdit ? "Update" : "Create")</button>
                    <button class="btn btn-outline-secondary" @onclick="NewRole">Clear</button>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private PagedResult<RoleAdminDto>? _result;
    private string _search = string.Empty;
    private int _page = 1;
    private int _pageSize = 10;
    private bool _isEdit;
    private string? _error;

    private RoleFormModel _form = new() { UserPermissionIsActived = true };

    private int TotalPages => _result is null || _result.TotalCount == 0
        ? 1
        : (int)Math.Ceiling((double)_result.TotalCount / _pageSize);

    protected override async Task OnInitializedAsync()
    {
        await LoadRolesAsync();
    }

    private async Task LoadRolesAsync()
    {
        _error = null;
        try
        {
            var url = $"/api/admin/roles?search={Uri.EscapeDataString(_search)}&page={_page}&pageSize={_pageSize}";
            _result = await Http.GetFromJsonAsync<PagedResult<RoleAdminDto>>(url);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private async Task ApplyFilterAsync()
    {
        _page = 1;
        await LoadRolesAsync();
    }

    private async Task ResetFilterAsync()
    {
        _search = string.Empty;
        _page = 1;
        await LoadRolesAsync();
    }

    private async Task PrevPageAsync()
    {
        if (_page <= 1) return;
        _page--;
        await LoadRolesAsync();
    }

    private async Task NextPageAsync()
    {
        if (_page >= TotalPages) return;
        _page++;
        await LoadRolesAsync();
    }

    private void NewRole()
    {
        _isEdit = false;
        _form = new RoleFormModel { UserPermissionIsActived = true };
    }

    private void Edit(RoleAdminDto role)
    {
        _isEdit = true;
        _form = new RoleFormModel
        {
            UserPermissionCode = role.UserPermissionCode,
            UserPermissionEnglish = role.UserPermissionEnglish,
            UserPermissionKhmer = role.UserPermissionKhmer,
            UserPermissionIsActived = role.UserPermissionIsActived,
            UserPermissionDescription = role.UserPermissionDescription
        };
    }

    private async Task SaveAsync()
    {
        _error = null;
        try
        {
            if (_isEdit)
            {
                var request = new UpdateRoleRequest(
                    _form.UserPermissionEnglish,
                    _form.UserPermissionKhmer,
                    _form.UserPermissionIsActived,
                    _form.UserPermissionDescription);

                var response = await Http.PutAsJsonAsync($"/api/admin/roles/{Uri.EscapeDataString(_form.UserPermissionCode)}", request);
                response.EnsureSuccessStatusCode();
            }
            else
            {
                var request = new CreateRoleRequest(
                    _form.UserPermissionCode,
                    _form.UserPermissionEnglish,
                    _form.UserPermissionKhmer,
                    _form.UserPermissionIsActived,
                    _form.UserPermissionDescription);

                var response = await Http.PostAsJsonAsync("/api/admin/roles", request);
                response.EnsureSuccessStatusCode();
            }

            await LoadRolesAsync();
            NewRole();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private sealed class RoleFormModel
    {
        public string UserPermissionCode { get; set; } = string.Empty;
        public string UserPermissionEnglish { get; set; } = string.Empty;
        public string UserPermissionKhmer { get; set; } = string.Empty;
        public bool UserPermissionIsActived { get; set; }
        public string? UserPermissionDescription { get; set; }
    }

    private sealed record PagedResult<T>(IReadOnlyList<T> Items, int TotalCount, int Page, int PageSize);

    private sealed record RoleAdminDto(
        int UserPermissionId,
        string UserPermissionCode,
        string UserPermissionEnglish,
        string UserPermissionKhmer,
        bool UserPermissionIsActived,
        string? UserPermissionDescription);

    private sealed record CreateRoleRequest(
        string UserPermissionCode,
        string UserPermissionEnglish,
        string UserPermissionKhmer,
        bool UserPermissionIsActived,
        string? UserPermissionDescription);

    private sealed record UpdateRoleRequest(
        string UserPermissionEnglish,
        string UserPermissionKhmer,
        bool UserPermissionIsActived,
        string? UserPermissionDescription);
}
