@inherits LayoutComponentBase

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row app-header px-4">
            <div class="brand-block">
                <div class="brand-logo">PX</div>
                <div>
                    <div class="brand-title">Pharmacy Extra</div>
                    <small class="brand-subtitle">Enterprise Management Portal</small>
                </div>
            </div>

            <div class="header-actions">
                <PharmacyExtra.Web.Components.Shared.ThemeToggle />
                <PharmacyExtra.Web.Components.Shared.NotificationsMenu />
                <PharmacyExtra.Web.Components.Shared.LoginDisplay />
            </div>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>
