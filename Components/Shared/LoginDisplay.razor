@inject HttpClient Http
@inject NavigationManager Navigation

<AuthorizeView>
    <Authorized>
        <div class="profile-menu dropdown">
            <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                <span class="me-1">👤</span>@context.User.Identity?.Name
            </button>
            <ul class="dropdown-menu dropdown-menu-end shadow-sm">
                <li><span class="dropdown-item-text text-muted small">Signed in</span></li>
                <li><hr class="dropdown-divider"></li>
                <li><a class="dropdown-item" href="dashboard">Dashboard</a></li>
                <li><a class="dropdown-item" href="system-info">System Info</a></li>
                <li><hr class="dropdown-divider"></li>
                <li><button class="dropdown-item text-danger" @onclick="SignOut">Logout</button></li>
            </ul>
        </div>
    </Authorized>
    <NotAuthorized>
        <a class="btn btn-sm btn-primary" href="login">Login</a>
    </NotAuthorized>
</AuthorizeView>

@code {
    private async Task SignOut()
    {
        await Http.PostAsync("/auth/logout", content: null);
        Navigation.NavigateTo("/login", forceLoad: true);
    }
}
