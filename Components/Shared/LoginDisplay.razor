@inject HttpClient Http
@inject NavigationManager Navigation

<AuthorizeView>
    <Authorized>
        <div class="d-flex gap-2 align-items-center">
            <span class="text-muted small">@context.User.Identity?.Name</span>
            <button class="btn btn-sm btn-outline-secondary" @onclick="SignOut">Logout</button>
        </div>
    </Authorized>
    <NotAuthorized>
        <a class="btn btn-sm btn-outline-primary" href="login">Login</a>
    </NotAuthorized>
</AuthorizeView>

@code {
    private async Task SignOut()
    {
        await Http.PostAsync("/auth/logout", content: null);
        Navigation.NavigateTo("/login", forceLoad: true);
    }
}
